{% extends 'layout.twig' %}

{% block title %}Verify Your Identity — CraveCart{% endblock %}

{% block content %}
<section class="py-5" style="min-height: calc(100vh - 200px); background:#f8f9fa;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">
                <div class="card border-0 shadow-sm rounded-4 p-4">
                    <div class="text-center mb-4">
                        <div class="mb-3">
                            <i class="bi bi-shield-lock-fill" style="font-size:2.5rem; color:#e63946;"></i>
                        </div>
                        <h3 class="fw-bold">Check your email</h3>
                        <p class="text-muted small">We sent a 6-digit code to your email address. It expires in 5 minutes.</p>
                    </div>

                    {% if error is defined and error %}
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            {{ error }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endif %}

                    <form action="{{ basePath }}/verify-2fa" method="post">
                        <div class="mb-4">
                            <label for="code" class="form-label fw-semibold small">Verification Code</label>
                            <input type="text" class="form-control form-control-lg text-center fw-bold"
                                   id="code" name="code"
                                   placeholder="000000"
                                   maxlength="6"
                                   autocomplete="one-time-code"
                                   required autofocus>
                        </div>
                        <button type="submit" class="btn w-100 text-white fw-semibold" style="background-color:#e63946;">
                            Verify
                        </button>
                    </form>

                    <hr class="my-4">
                    <p class="text-center small mb-0">
                        Didn't get the code?
                        <a href="{{ basePath }}/login" class="fw-semibold text-decoration-none" style="color:#e63946;">Try logging in again</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
