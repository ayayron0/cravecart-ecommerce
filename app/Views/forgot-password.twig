{% extends 'layout.twig' %}

{% block title %}{{ __('auth.forgot_password_title') }} — {{ __('site.name') }}{% endblock %}

{% block content %}
<section class="py-5" style="min-height: calc(100vh - 200px); background:#f8f9fa;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">
                <div class="card border-0 shadow-sm rounded-4 p-4">

                    {% if error is defined and error %}
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            {{ error }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endif %}

                    {% if found_email is defined %}

                        {# Step 2 — email matched, show the new password form #}
                        <div class="text-center mb-4">
                            <h3 class="fw-bold">{{ __('auth.reset_password_title') }}</h3>
                            <p class="text-muted small">{{ found_email }}</p>
                        </div>

                        <form action="{{ basePath }}/reset-password" method="post">
                            <input type="hidden" name="email" value="{{ found_email }}">

                            <div class="mb-3">
                                <label for="password" class="form-label fw-semibold small">{{ __('auth.new_password') }}</label>
                                <input type="password" class="form-control" id="password" name="password"
                                       placeholder="{{ __('forms.placeholder_password') }}" required minlength="8">
                            </div>
                            <div class="mb-4">
                                <label for="confirm_password" class="form-label fw-semibold small">{{ __('auth.confirm_new_password') }}</label>
                                <input type="password" class="form-control" id="confirm_password" name="confirm_password"
                                       placeholder="{{ __('forms.placeholder_password') }}" required minlength="8">
                            </div>
                            <button type="submit" class="btn w-100 text-white fw-semibold" style="background-color:#e63946;">
                                {{ __('auth.update_password') }}
                            </button>
                        </form>

                    {% else %}

                        {# Step 1 — ask for email #}
                        <div class="text-center mb-4">
                            <h3 class="fw-bold">{{ __('auth.forgot_password_title') }}</h3>
                            <p class="text-muted small">{{ __('auth.forgot_password_subtitle') }}</p>
                        </div>

                        <form action="{{ basePath }}/forgot-password" method="post">
                            <div class="mb-4">
                                <label for="email" class="form-label fw-semibold small">{{ __('auth.email') }}</label>
                                <input type="email" class="form-control" id="email" name="email"
                                       value="{{ old_email ?? '' }}"
                                       placeholder="{{ __('forms.placeholder_email') }}" required>
                            </div>
                            <button type="submit" class="btn w-100 text-white fw-semibold" style="background-color:#e63946;">
                                {{ __('auth.send_reset_link') }}
                            </button>
                        </form>

                    {% endif %}

                    <hr class="my-4">
                    <p class="text-center small mb-0">
                        {{ __('auth.has_account') }}
                        <a href="{{ basePath }}/login" class="fw-semibold text-decoration-none" style="color:#e63946;">{{ __('auth.login') }}</a>
                    </p>

                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
