{% extends 'layout.twig' %}
{% block title %}{{ __('about.title') }} — {{ __('site.name') }}{% endblock %}

{% block content %}
<div class="container py-5" style="max-width:760px;">

    <h1 style="font-weight:900; letter-spacing:-.04em;">{{ __('about.title') }} <span style="color:#e63946;">{{ __('site.name') }}</span></h1>
    <p class="text-muted mb-5">{{ __('about.subtitle') }}</p>

    <div class="mb-4">
        <h5 class="fw-bold">{{ __('about.who_we_are') }}</h5>
        <p class="text-muted" style="line-height:1.75;">
            {{ __('about.who_we_are_desc')|default('CraveCart is a food ordering platform built for people who take their meals seriously. From rich Indian curries to delicate Japanese desserts, we partner with the best local restaurants so you can explore global cuisine without leaving home.') }}
        </p>
    </div>

    <div class="mb-4">
        <h5 class="fw-bold">{{ __('about.what_we_offer') }}</h5>
        <ul class="text-muted ps-3" style="line-height:2;">
            <li>{{ __('about.curated_selection') }}</li>
            <li>{{ __('about.simple_ordering') }}</li>
            <li>{{ __('about.clean_experience') }}</li>
        </ul>
    </div>

    <div class="mb-5">
        <h5 class="fw-bold">{{ __('about.our_mission') }}</h5>
        <p class="text-muted" style="line-height:1.75;">
            {{ __('about.mission_desc')|default('Good food should be easy to find and easy to order. That\'s it.') }}
        </p>
    </div>

    <a href="{{ basePath }}/" class="btn fw-semibold px-4 py-2 text-white" style="background:#e63946; border-radius:10px;">
        {{ __('cuisines.browse') }}
    </a>

</div>
{% endblock %}