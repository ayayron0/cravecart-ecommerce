{% extends 'layout.twig' %}
{% block title %}{{ cuisine.name }} {{ category.name }} — CraveCart{% endblock %}

{% block extra_css %}
<style>
    .page-header {
        background: var(--cc-dark);
        padding: 64px 0 40px;
        color: #fff;
    }
    .page-header h1 { font-size: 2.6rem; font-weight: 900; letter-spacing: -.04em; }
    .page-header p  { color: rgba(255,255,255,.6); }
    .page-header .cuisine-tag {
        display: inline-flex; align-items: center; gap: 8px;
        background: rgba(255,255,255,.1);
        border: 1px solid rgba(255,255,255,.15);
        border-radius: 50px;
        padding: 6px 18px;
        font-size: .82rem; font-weight: 600;
        color: rgba(255,255,255,.85);
        margin-bottom: 1.2rem;
    }

    .dish-card {
        border: none;
        border-radius: 18px;
        box-shadow: 0 2px 14px rgba(0,0,0,.07);
        overflow: hidden;
        transition: transform .25s, box-shadow .25s;
        height: 100%;
    }
    .dish-card:hover { transform: translateY(-6px); box-shadow: 0 16px 40px rgba(0,0,0,.13); }
    .dish-emoji-wrap {
        background: #f3f4f6;
        height: 150px;
        display: flex; align-items: center; justify-content: center;
        font-size: 4.5rem;
        position: relative;
    }
    .dish-card .dish-body { padding: 1.2rem 1.4rem 1.4rem; display: flex; flex-direction: column; }
    .dish-card .dish-name { font-size: 1rem; font-weight: 700; margin-bottom: .3rem; letter-spacing: -.02em; }
    .dish-card .dish-desc { font-size: .82rem; color: #6b7280; flex-grow: 1; line-height: 1.55; }
    .dish-card .dish-footer { display: flex; align-items: center; justify-content: space-between; margin-top: 1rem; }
    .dish-card .dish-price { font-size: 1.15rem; font-weight: 800; color: var(--cc-red); letter-spacing: -.02em; }
    .dish-card .btn-add {
        background: var(--cc-red); color: #fff;
        border: none; border-radius: 9px;
        padding: 7px 14px; font-size: .82rem; font-weight: 600;
        transition: background .2s; display: flex; align-items: center; gap: 5px;
        cursor: pointer;
    }
    .dish-card .btn-add:hover { background: #c1121f; }

    .empty-state { text-align: center; padding: 80px 20px; }
    .empty-state .empty-icon { font-size: 5rem; }
</style>
{% endblock %}

{% block content %}

{# ── Page Header ── #}
<div class="page-header">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb cc-breadcrumb mb-3">
                <li class="breadcrumb-item"><a href="{{ basePath }}/">Home</a></li>
                <li class="breadcrumb-item"><a href="{{ basePath }}/browse/{{ category.slug }}">{{ category.name }}</a></li>
                <li class="breadcrumb-item active" style="color:rgba(255,255,255,.5);">{{ cuisine.name }}</li>
            </ol>
        </nav>
        <div class="cuisine-tag">{{ cuisine.flag }} {{ cuisine.name }}</div>
        <h1>{{ cuisine.name }} {{ category.name }}</h1>
        <p class="mb-0">{{ cuisine.description }}</p>
    </div>
</div>

{# ── Dishes ── #}
<section class="py-5">
    <div class="container">

        {% if dishes|length > 0 %}

        <div class="d-flex justify-content-between align-items-center mb-4">
            <p class="mb-0 text-muted small">
                <strong class="text-dark">{{ dishes|length }}</strong> {{ category.name|lower }} available
            </p>
        </div>

        <div class="row g-4">
            {% for dish in dishes %}
            <div class="col-sm-6 col-lg-4">
                <div class="dish-card">
                    <div class="dish-emoji-wrap">
                        <span>{{ dish.emoji }}</span>
                        <span class="position-absolute top-0 end-0 m-2">
                            {% if dish.availability == 'available' %}
                                <span class="badge-available">Available</span>
                            {% elseif dish.availability == 'seasonal' %}
                                <span class="badge-seasonal">Seasonal</span>
                            {% else %}
                                <span class="badge-unavailable">{{ dish.availability|capitalize }}</span>
                            {% endif %}
                        </span>
                    </div>
                    <div class="dish-body">
                        <p class="dish-name">{{ dish.name }}</p>
                        <p class="dish-desc">{{ dish.description }}</p>
                        <div class="dish-footer">
                            <span class="dish-price">${{ dish.price|number_format(2) }}</span>
                            {% if dish.availability == 'available' or dish.availability == 'seasonal' %}
                            <button class="btn-add">
                                <i class="bi bi-bag-plus"></i> Add
                            </button>
                            {% else %}
                            <span class="text-muted small">Unavailable</span>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>

        {% else %}

        <div class="empty-state">
            <div class="empty-icon">🍽️</div>
            <h4 class="fw-bold mt-3">Nothing here yet</h4>
            <p class="text-muted">No {{ category.name|lower }} available for {{ cuisine.name }} cuisine right now.</p>
            <a href="{{ basePath }}/browse/{{ category.slug }}" class="btn-cc mt-2 d-inline-block">
                Back to {{ category.name }}
            </a>
        </div>

        {% endif %}

        <div class="mt-5 pt-2">
            <a href="{{ basePath }}/browse/{{ category.slug }}" class="btn-cc-outline">
                <i class="bi bi-arrow-left me-2"></i> Back to Cuisines
            </a>
        </div>
    </div>
</section>

{% endblock %}
