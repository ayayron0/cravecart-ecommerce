{% extends 'layout.twig' %}
{% block title %}{{ category.name }} — CraveCart{% endblock %}

{% block extra_css %}
<style>
    .cuisine-card {
        border-radius: 20px;
        overflow: hidden;
        border: none;
        box-shadow: 0 2px 16px rgba(0,0,0,.07);
        transition: transform .3s, box-shadow .3s;
        cursor: pointer;
        text-decoration: none;
        display: block;
        color: #111827;
    }
    .cuisine-card:hover { transform: translateY(-8px); box-shadow: 0 20px 48px rgba(0,0,0,.14); color: #111827; }
    .cuisine-card .cuisine-banner {
        height: 170px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 5.5rem;
        position: relative;
    }
    .cuisine-card .cuisine-flag {
        position: absolute;
        top: 16px; right: 16px;
        font-size: 2rem;
        line-height: 1;
    }
    .cuisine-card .cuisine-body { padding: 1.4rem 1.6rem 1.8rem; }
    .cuisine-card .cuisine-name { font-size: 1.35rem; font-weight: 800; letter-spacing: -.03em; margin-bottom: .3rem; }
    .cuisine-card .cuisine-desc { font-size: .88rem; color: #6b7280; margin-bottom: 1rem; }
    .cuisine-card .cuisine-count { font-size: .82rem; font-weight: 600; color: var(--cc-red); }
    .cuisine-card .cuisine-btn {
        display: inline-flex; align-items: center; gap: 6px;
        background: var(--cc-red); color: #fff;
        border-radius: 9px; padding: 8px 18px;
        font-size: .85rem; font-weight: 600;
        transition: background .2s;
    }
    .cuisine-card:hover .cuisine-btn { background: #c1121f; }

    .bg-pakistani { background: linear-gradient(135deg, #14532d, #16a34a); }
    .bg-japanese  { background: linear-gradient(135deg, #7f1d1d, #dc2626); }
    .bg-italian   { background: linear-gradient(135deg, #1e3a5f, #2563eb); }
    .bg-french    { background: linear-gradient(135deg, #1c1917, #44403c); }

    .page-header {
        background: var(--cc-dark);
        padding: 64px 0 40px;
        color: #fff;
    }
    .page-header .cat-badge {
        display: inline-flex; align-items: center; gap: 8px;
        background: rgba(255,255,255,.1);
        border: 1px solid rgba(255,255,255,.15);
        border-radius: 50px;
        padding: 6px 18px;
        font-size: .82rem;
        font-weight: 600;
        margin-bottom: 1.2rem;
        color: rgba(255,255,255,.85);
    }
    .page-header h1 { font-size: 2.6rem; font-weight: 900; letter-spacing: -.04em; }
    .page-header p  { color: rgba(255,255,255,.6); font-size: 1rem; }
</style>
{% endblock %}

{% block content %}

{# ── Page Header ── #}
<div class="page-header">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb cc-breadcrumb mb-3">
                <li class="breadcrumb-item"><a href="{{ basePath }}/">Home</a></li>
                <li class="breadcrumb-item active" style="color:rgba(255,255,255,.5);">{{ category.name }}</li>
            </ol>
        </nav>
        <div class="cat-badge">{{ category.emoji }} {{ category.name }}</div>
        <h1>Choose your cuisine</h1>
        <p class="mb-0">Pick a cuisine to explore its {{ category.name|lower }}.</p>
    </div>
</div>

{# ── Cuisines Grid ── #}
<section class="py-5">
    <div class="container">
        <div class="row g-4">
            {% for cuisine in cuisines %}
            <div class="col-sm-6 col-lg-3">
                <a href="{{ basePath }}/browse/{{ category.slug }}/{{ cuisine.slug }}" class="cuisine-card">
                    <div class="cuisine-banner bg-{{ cuisine.slug }}">
                        <span>{{ cuisine.hero_emoji }}</span>
                        <span class="cuisine-flag">{{ cuisine.flag }}</span>
                    </div>
                    <div class="cuisine-body">
                        <p class="cuisine-name">{{ cuisine.name }}</p>
                        <p class="cuisine-desc">{{ cuisine.description }}</p>
                        <p class="cuisine-count mb-3">{{ cuisine.dish_count }} {{ category.name|lower }} available</p>
                        <span class="cuisine-btn">
                            View {{ category.name }} <i class="bi bi-arrow-right"></i>
                        </span>
                    </div>
                </a>
            </div>
            {% endfor %}
        </div>

        <div class="mt-5 pt-2 text-center">
            <a href="{{ basePath }}/" class="btn-cc-outline">
                <i class="bi bi-arrow-left me-2"></i> Back to Categories
            </a>
        </div>
    </div>
</section>

{% endblock %}
