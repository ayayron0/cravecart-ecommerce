<nav class="navbar navbar-expand-lg cc-navbar">
    <div class="container cc-navbar-inner">
        <a class="navbar-brand cc-brand" href="{{ basePath }}/">
            <span class="cc-brand-mark">CC</span>
            <span class="cc-brand-text">{{ __('site.name') }}</span>
        </a>

        <div id="search-wrapper" class="cc-search-wrap">
            <form role="search" onsubmit="return false;">
                <div class="cc-search-shell">
                    <span class="cc-search-icon">
                        <i class="bi bi-search"></i>
                    </span>
                    <input type="search"
                           id="search-input"
                           class="form-control cc-search-input"
                           placeholder="{{ __('nav.search_placeholder') }}"
                           data-search-url="{{ basePath }}/search"
                           autocomplete="off">
                </div>
            </form>
            <div id="search-results" class="cc-search-results"></div>
        </div>

        <div class="cc-navbar-actions">
            <div class="dropdown">
                <button class="btn cc-locale-btn dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="bi bi-globe2"></i>
                    {% set locale = currentLocale() %}
                    <span>
                        {% if locale == 'en' %}EN
                        {% elseif locale == 'es' %}ES
                        {% elseif locale == 'fr' %}FR
                        {% else %}EN{% endif %}
                    </span>
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow-sm cc-locale-menu">
                    {% for code, name in supportedLocales() %}
                    <li>
                        <a class="dropdown-item{% if currentLocale() == code %} active{% endif %}" href="?locale={{ code }}">
                            {{ name }}
                        </a>
                    </li>
                    {% endfor %}
                </ul>
            </div>

            <a href="{{ basePath }}/cart" class="cc-icon-link position-relative" aria-label="{{ __('nav.cart') }}">
                <i class="bi bi-cart3"></i>
                {% if cart_count > 0 %}
                <span class="cc-cart-badge">{{ cart_count }}</span>
                {% endif %}
            </a>

            {% if session.user_id is defined %}
                {% if session.role == 'administrator' %}
                    <a href="{{ basePath }}/admin/orders" class="btn cc-btn-dark cc-btn-sm">
                        <i class="bi bi-speedometer2 me-1"></i>{{ __('nav.admin_panel') }}
                    </a>
                {% endif %}

                <div class="dropdown">
                    <button class="btn cc-user-btn dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-person-circle"></i>
                        <span>{{ session.name }}</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm cc-user-menu">
                        {% if session.role != 'administrator' %}
                        <li>
                            <a class="dropdown-item" href="{{ basePath }}/account/orders">
                                <i class="bi bi-bag-check me-2"></i>{{ __('nav.my_orders') }}
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" href="{{ basePath }}/account/profile">
                                <i class="bi bi-person-circle me-2"></i>{{ __('nav.my_profile') }}
                            </a>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        {% endif %}
                        <li>
                            <a class="dropdown-item" href="{{ basePath }}/logout">
                                <i class="bi bi-box-arrow-left me-2"></i>{{ __('nav.sign_out') }}
                            </a>
                        </li>
                    </ul>
                </div>
            {% else %}
                <a href="{{ basePath }}/login" class="btn cc-btn-primary cc-btn-sm">
                    {{ __('nav.login') }}
                </a>
            {% endif %}
        </div>
    </div>
</nav>
