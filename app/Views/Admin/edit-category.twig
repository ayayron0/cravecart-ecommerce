{% extends 'Admin/layout.twig' %}
{% block title %}Edit Category — CraveCart Admin{% endblock %}
{% block page_title %}Edit Category{% endblock %}

{% block content %}

{% if success is defined and success %}
<div class="alert alert-success alert-dismissible fade show mb-4">
    <i class="bi bi-check-circle me-2"></i>{{ success }}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
{% endif %}

{% if errors is defined and errors %}
<div class="alert alert-danger mb-4">
    <ul class="mb-0 ps-3">
        {% for error in errors %}
            <li class="small">{{ error }}</li>
        {% endfor %}
    </ul>
</div>
{% endif %}

<div class="add-form">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h6 class="fw-bold mb-1">Edit {{ category.name }}</h6>
            <p class="text-muted small mb-0">Update this category's details.</p>
        </div>
        <a href="{{ basePath }}/admin/add" class="btn btn-outline-secondary btn-sm">
            Back to Add New
        </a>
    </div>

    <form action="{{ basePath }}/admin/edit/category/{{ category.id }}" method="post">
        <div class="row g-3">
            <div class="col-12">
                <label class="form-label small fw-semibold">Category Name</label>
                <input type="text" name="name" class="form-control" value="{{ category.name }}" required>
            </div>

            <div class="col-12">
                <label class="form-label small fw-semibold">Description</label>
                <input type="text" name="description" class="form-control" value="{{ category.description }}">
            </div>

            <div class="col-12">
                <button type="submit" class="btn text-white fw-semibold px-4" style="background:#e63946;">
                    <i class="bi bi-save me-1"></i> Save Changes
                </button>
            </div>
        </div>
    </form>
</div>

{% endblock %}
