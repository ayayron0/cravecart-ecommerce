{% extends 'Admin/layout.twig' %}
{% block title %}Profile — CraveCart Admin{% endblock %}
{% block page_title %}{{ __('account.profile') }}{% endblock %}

{% block content %}
<div class="row g-4" style="max-width:680px;">

    {# Errors #}
    {% if errors is defined and errors %}
    <div class="col-12">
        <div class="alert alert-danger">
            <ul class="mb-0 ps-3">
                {% for error in errors %}
                    <li class="small">{{ error }}</li>
                {% endfor %}
            </ul>
        </div>
    </div>
    {% endif %}

    <div class="col-12">
        <form action="{{ basePath }}/admin/profile" method="post">

            {# Account info #}
            <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
                <h6 class="fw-bold mb-4"><i class="bi bi-person me-2" style="color:#e63946;"></i>{{ __('account.account_info') }}</h6>
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label small fw-semibold">{{ __('auth.name') }}</label>
                        <input type="text" name="name" class="form-control"
                               value="{{ user.name }}" required>
                    </div>
                    <div class="col-12">
                        <label class="form-label small fw-semibold">{{ __('account.email_address') }}</label>
                        <input type="email" name="email" class="form-control"
                               value="{{ user.email }}" required>
                    </div>
                </div>
            </div>

            {# Change password #}
            <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
                <h6 class="fw-bold mb-1"><i class="bi bi-lock me-2" style="color:#e63946;"></i>{{ __('account.change_password') }}</h6>
                <p class="text-muted small mb-4">{{ __('account.leave_blank') }}</p>
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label small fw-semibold">{{ __('account.current_password') }}</label>
                        <input type="password" name="current_password" class="form-control"
                               placeholder="{{ __('forms.enter_current_password') }}">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">{{ __('account.new_password') }}</label>
                        <input type="password" name="new_password" class="form-control"
                               placeholder="{{ __('forms.at_least_8_chars') }}">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">{{ __('account.confirm_new_password') }}</label>
                        <input type="password" name="confirm_password" class="form-control"
                               placeholder="{{ __('forms.repeat_new_password') }}">
                    </div>
                </div>
            </div>

            <button type="submit" class="btn text-white fw-semibold px-4 py-2"
                    style="background:#e63946; border-radius:10px;">
                <i class="bi bi-check-lg me-1"></i> {{ __('forms.save_changes') }}
            </button>

        </form>
    </div>
</div>


{% endblock %}
