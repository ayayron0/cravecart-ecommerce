<!DOCTYPE html>
<html lang="{{ currentLocale() }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Admin — CraveCart{% endblock %}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset_url('/css/main.css') }}">
    <link rel="stylesheet" href="{{ asset_url('/css/admin.css') }}">
    {% block extra_css %}{% endblock %}
</head>
<body>

<div class="admin-wrapper">

    {# Sidebar #}
    <aside class="admin-sidebar">
        <div class="sidebar-logo">
            <div class="cc-dot">CC</div>
            <div>
                <span>CraveCart</span>
                <small>{{ __('nav.admin_panel') }}</small>
            </div>
        </div>

        <span class="sidebar-label">{{ __('admin.manage') }}</span>
        <a href="{{ basePath }}/admin/orders" class="sidebar-link {{ activeNav == 'orders' ? 'active' : '' }}">
            <i class="bi bi-bag-check"></i> {{ __('admin.orders') }}
        </a>
        <a href="{{ basePath }}/admin/orders/history" class="sidebar-link {{ activeNav == 'order_history' ? 'active' : '' }}">
            <i class="bi bi-clock-history"></i> {{ __('admin.order_history') }}
        </a>
        <a href="{{ basePath }}/admin/menu" class="sidebar-link {{ activeNav == 'menu' ? 'active' : '' }}">
            <i class="bi bi-egg-fried"></i> {{ __('nav.menu_management') }}
        </a>
        <a href="{{ basePath }}/admin/add" class="sidebar-link {{ activeNav == 'add' ? 'active' : '' }}">
            <i class="bi bi-plus-circle"></i> {{ __('admin.add_new') }}
        </a>

        <span class="sidebar-label sidebar-label-bottom">{{ __('admin.account') }}</span>
        <a href="{{ basePath }}/admin/profile" class="sidebar-link {{ activeNav == 'profile' ? 'active' : '' }}">
            <i class="bi bi-person-circle"></i> {{ __('account.profile') }}
        </a>
        <a href="{{ basePath }}/" class="sidebar-link">
            <i class="bi bi-house"></i> {{ __('admin.back_to_site') }}
        </a>
        <a href="{{ basePath }}/logout" class="sidebar-link sidebar-link-danger">
            <i class="bi bi-box-arrow-left"></i> {{ __('nav.sign_out') }}
        </a>
    </aside>

    {# Main area #}
    <div class="admin-main">
        <div class="admin-topbar">
            <h5>{% block page_title %}Dashboard{% endblock %}</h5>
            <span class="text-muted small">{{ __('nav.admin') }}</span>
        </div>
        <div class="admin-content">
            {% if flash %}
            <div class="alert alert-{{ flash.type }} alert-dismissible fade show mb-4" role="alert">
                {{ flash.message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
            {% endif %}
            {% block content %}{% endblock %}
        </div>
    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="{{ asset_url('/js/admin.js') }}"></script>
{% block extra_js %}{% endblock %}
</body>
</html>
