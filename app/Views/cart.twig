{% extends 'layout.twig' %}

{% block title %}Your Cart — CraveCart{% endblock %}

{% block content %}
<section class="py-5">
    <div class="container">
        <h2 class="fw-bold mb-4">Your Cart</h2>

        {% if items is defined and items|length > 0 %}

        <div class="row g-4">
            {# Cart items #}
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-0">
                        <table class="table table-borderless align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Item</th>
                                    <th class="text-center">Qty</th>
                                    <th class="text-end">Price</th>
                                    <th class="text-end pe-4">Subtotal</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for item in items %}
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="rounded-3 bg-light d-flex align-items-center justify-content-center" style="width:56px;height:56px;font-size:1.8rem;">
                                                {{ item.emoji ?? '🍽️' }}
                                            </div>
                                            <div>
                                                <p class="fw-semibold mb-0">{{ item.name }}</p>
                                                <small class="text-muted">{{ item.category ?? '' }}</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <div class="input-group input-group-sm" style="width:100px; margin:auto;">
                                            <a href="{{ basePath }}/cart/decrease/{{ item.id }}" class="btn btn-outline-secondary">−</a>
                                            <span class="form-control text-center">{{ item.quantity }}</span>
                                            <a href="{{ basePath }}/cart/increase/{{ item.id }}" class="btn btn-outline-secondary">+</a>
                                        </div>
                                    </td>
                                    <td class="text-end">${{ item.price }}</td>
                                    <td class="text-end pe-4">${{ (item.price * item.quantity)|number_format(2) }}</td>
                                    <td>
                                        <a href="{{ basePath }}/cart/remove/{{ item.id }}" class="btn btn-sm btn-link text-danger p-0">
                                            <i class="bi bi-trash3"></i>
                                        </a>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="mt-3">
                    <a href="{{ basePath }}/dishes" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-arrow-left me-1"></i> Continue Shopping
                    </a>
                </div>
            </div>

            {# Order summary #}
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body">
                        <h5 class="fw-bold mb-4">Order Summary</h5>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted small">Subtotal</span>
                            <span>${{ subtotal ?? '0.00' }}</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted small">Delivery fee</span>
                            <span>${{ delivery_fee ?? '2.99' }}</span>
                        </div>
                        <hr>
                        <div class="d-flex justify-content-between fw-bold mb-4">
                            <span>Total</span>
                            <span style="color:#e63946;">${{ total ?? '0.00' }}</span>
                        </div>
                        <a href="{{ basePath }}/checkout" class="btn w-100 text-white fw-semibold" style="background-color:#e63946;">
                            Proceed to Checkout <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                        <p class="text-center small text-muted mt-3 mb-0">
                            <i class="bi bi-shield-lock me-1"></i> Secure checkout
                        </p>
                    </div>
                </div>
            </div>
        </div>

        {% else %}

        <div class="text-center py-5">
            <div style="font-size:5rem;">🛒</div>
            <h4 class="fw-bold mt-3">Your cart is empty</h4>
            <p class="text-muted">Looks like you haven't added anything yet.</p>
            <a href="{{ basePath }}/dishes" class="btn mt-2 text-white px-4" style="background-color:#e63946;">
                Browse Menu
            </a>
        </div>

        {% endif %}
    </div>
</section>
{% endblock %}
