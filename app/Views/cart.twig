{% extends 'layout.twig' %}

{% block title %}{{ __('cart.your_cart') }} — {{ __('site.name') }}{% endblock %}

{% block content %}
<section class="py-5">
    <div class="container">
        <h2 class="fw-bold mb-4">{{ __('cart.your_cart') }}</h2>

        {% if items is defined and items|length > 0 %}

        <div class="row g-4">
            {# Cart items #}
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-0">
                        <table class="table table-borderless align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">{{ __('cart.item') }}</th>
                                    <th class="text-center">{{ __('cart.qty') }}</th>
                                    <th class="text-end">{{ __('cart.price') }}</th>
                                    <th class="text-end pe-4">{{ __('cart.subtotal') }}</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for item in items %}
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="rounded-3 bg-light d-flex align-items-center justify-content-center" style="width:56px;height:56px;font-size:1.8rem;">
                                                {% if item.image_url %}
                                                    <img src="{{ item.image_url }}" alt="{{ item.name }}" style="width:100%;height:100%;object-fit:cover;border-radius:.75rem;">
                                                {% else %}
                                                    {{ item.emoji ?? '🍽️' }}
                                                {% endif %}
                                            </div>
                                            <div>
                                                <p class="fw-semibold mb-0">{{ item.name }}</p>
                                                <small class="text-muted">{{ item.category ?? '' }}</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <div class="input-group input-group-sm" style="width:100px; margin:auto;">
                                            <form action="{{ basePath }}/cart/decrease/{{ item.id }}" method="post" class="mb-0">
                                                <button type="submit" class="btn btn-outline-secondary">−</button>
                                            </form>
                                            <span class="form-control text-center">{{ item.quantity }}</span>
                                            <form action="{{ basePath }}/cart/increase/{{ item.id }}" method="post" class="mb-0">
                                                <button type="submit" class="btn btn-outline-secondary">+</button>
                                            </form>
                                        </div>
                                    </td>
                                    <td class="text-end">${{ item.price|number_format(2) }}</td>
                                    <td class="text-end pe-4">${{ (item.price * item.quantity)|number_format(2) }}</td>
                                    <td>
                                        <form action="{{ basePath }}/cart/remove/{{ item.id }}" method="post" class="mb-0">
                                            <button type="submit" class="btn btn-sm btn-link text-danger p-0">
                                                <i class="bi bi-trash3"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="mt-3">
                    <a href="{{ basePath }}/" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-arrow-left me-1"></i> {{ __('cart.continue_shopping') }}
                    </a>
                </div>
            </div>

            {# Order summary #}
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body">
                        <h5 class="fw-bold mb-4">{{ __('cart.order_summary') }}</h5>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted small">{{ __('cart.subtotal') }}</span>
                            <span>${{ subtotal ?? '0.00' }}</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted small">{{ __('cart.delivery_fee') }}</span>
                            <span>${{ delivery_fee ?? '0.00' }}</span>
                        </div>
                        <hr>
                        <div class="d-flex justify-content-between fw-bold mb-4">
                            <span>{{ __('cart.total') }}</span>
                            <span style="color:#e63946;">${{ total ?? '0.00' }}</span>
                        </div>
                        {% if usd_total %}
                        <p class="text-end small text-muted mt-n3 mb-4">
                            Approx. ${{ usd_total }} USD </p>
                        {% endif %}

                        <a href="{{ basePath }}/checkout" class="btn w-100 text-white fw-semibold" style="background-color:#e63946;">
                            {{ __('cart.checkout') }} <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                        <p class="text-center small text-muted mt-3 mb-0">
                            <i class="bi bi-shield-lock me-1"></i> {{ __('cart.secure_checkout') }}
                        </p>
                    </div>
                </div>
            </div>
        </div>

        {% else %}

        <div class="text-center py-5">
            <div style="font-size:5rem;">🛒</div>
            <h4 class="fw-bold mt-3">{{ __('cart.empty') }}</h4>
            <p class="text-muted">{{ __('cart.nothing_added') }}</p>
            <a href="{{ basePath }}/" class="btn mt-2 text-white px-4" style="background-color:#e63946;">
                {{ __('cart.browse_menu') }}
            </a>
        </div>

        {% endif %}
    </div>
</section>
{% endblock %}