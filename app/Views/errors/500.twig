{% extends 'layout.twig' %}

{% block title %}{{ __('errors.something_went_wrong') }} | {{ __('site.name') }}{% endblock %}

{% block content %}
<section class="cc-error-shell">
    <div class="container">
        <div class="cc-error-card">
            <span class="cc-error-code">500</span>
            <h1 class="cc-error-title">{{ __('errors.something_went_wrong') }}</h1>
            <p class="cc-error-copy">{{ __('errors.try_again') }}</p>

            <div class="cc-error-actions">
                <a href="{{ basePath }}/" class="btn cc-btn-primary px-4">
                    {{ __('errors.go_home') }}
                </a>
            </div>
        </div>
    </div>
</section>
{% endblock %}
