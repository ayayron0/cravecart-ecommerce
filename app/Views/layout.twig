{#
    WHAT:  This is the main template that every page shares.
    HOW:   Every other page (home.twig, login.twig, etc.) starts with {% extends 'layout.twig' %}.
           That means they inherit everything in this file automatically.
           They then use {% block content %} to inject their own unique content into the <main> area.
           Think of this file as the "frame" — navbar, footer, and global styles live here once
           instead of being copy-pasted into every single page.
#}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    {#
        WHAT:  The tab title shown in the browser.
        HOW:   {% block title %} defines a placeholder with a default value of "CraveCart".
               Each page overrides it like this:
               {% block title %}Login — CraveCart{% endblock %}
               If a page does NOT override it, it falls back to "CraveCart".
    #}
    <title>{% block title %}CraveCart{% endblock %}</title>

    {#
        WHAT:  Loads the Poppins font from Google.
        HOW:   The browser makes a request to Google's servers and downloads the font files.
               The <link rel="preconnect"> line tells the browser to open the connection early
               so the font loads faster.
    #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

    {#
        WHAT:  Loads Bootstrap CSS.
        HOW:   The browser downloads Bootstrap's stylesheet from a CDN (a fast public server).
               This gives us ready-made classes like container, row, col-md-3, d-flex, btn, etc.
               We use these classes directly in our HTML instead of writing all that CSS ourselves.
    #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    {#
        WHAT:  Loads Bootstrap Icons — an icon library.
        HOW:   Works the same way as Bootstrap CSS — loaded from a CDN.
               To use an icon you add a class like: <i class="bi bi-cart3"></i>
               The class name tells the library which icon to display.
    #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

    {#
        WHAT:  Loads the global CraveCart stylesheet.
        HOW:   All shared styles (colours, buttons, cards, badges, footer) live in this one file.
               The browser caches it after the first load so it doesn't re-download on every page.
               Page-specific styles go in {% block extra_css %} in each individual view instead.
    #}
    <link rel="stylesheet" href="{{ asset_url('/css/main.css') }}">

    {#
        WHAT:  A slot for page-specific CSS.
        HOW:   This block is empty by default. Any page that needs its own styles
               overrides this block without touching layout.twig. Example in home.twig:
               {% block extra_css %}<style> .cc-hero { height: 340px; } </style>{% endblock %}
    #}
    {% block extra_css %}{% endblock %}
</head>
<body>

    {#
        WHAT:  The navbar shown at the top of every page.
        HOW:   {% include %} pastes the contents of common/header.twig right here.
               Keeping it in a separate file means you only edit the navbar in one place.
    #}
    {% include 'common/header.twig' %}

    {#
        WHAT:  The main content area — this is different on every page.
        HOW:   {% block content %} is empty here. Each child template fills it in.
               For example, home.twig puts the hero and cuisine cards here,
               and login.twig puts the login form here.
    #}
    <main>{% block content %}{% endblock %}</main>

    {#
        WHAT:  The footer shown at the bottom of every page.
        HOW:   Same as the header — {% include %} pastes common/footer.twig here.
    #}
    {% include 'common/footer.twig' %}

    {#
        WHAT:  Bootstrap JavaScript.
        HOW:   Loaded at the bottom of <body> (not in <head>) so the page HTML loads first
               before the script runs. Required for the mobile menu toggle, dropdowns,
               and modals to work.
    #}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    {#
        WHAT:  A slot for page-specific JavaScript.
        HOW:   Works the same as extra_css but for scripts. Empty by default.
               A page that needs its own JS overrides this block. Example:
               {% block extra_js %}<script> console.log('hello') </script>{% endblock %}
    #}
    {% block extra_js %}{% endblock %}

</body>
</html>
