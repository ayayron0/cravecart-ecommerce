<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}My Account — CraveCart{% endblock %}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    {# admin.css provides the shared sidebar/topbar/layout styles #}
    <link rel="stylesheet" href="{{ asset_url('/css/main.css') }}">
    <link rel="stylesheet" href="{{ asset_url('/css/admin.css') }}">
    <link rel="stylesheet" href="{{ asset_url('/css/account.css') }}">
    {% block extra_css %}{% endblock %}
</head>
<body>

<div class="admin-wrapper">

    {# Sidebar #}
    <aside class="admin-sidebar">
        <div class="sidebar-logo">
            <div class="cc-dot">CC</div>
            <div>
                <span>CraveCart</span>
                <small>My Account</small>
            </div>
        </div>

        <span class="sidebar-label">Account</span>
        <a href="{{ basePath }}/account/orders" class="sidebar-link {{ activeNav == 'orders' ? 'active' : '' }}">
            <i class="bi bi-bag-check"></i> My Orders
        </a>
        <a href="{{ basePath }}/account/profile" class="sidebar-link {{ activeNav == 'profile' ? 'active' : '' }}">
            <i class="bi bi-person-circle"></i> My Profile
        </a>

        <span class="sidebar-label sidebar-label-bottom">Navigation</span>
        <a href="{{ basePath }}/" class="sidebar-link">
            <i class="bi bi-house"></i> Back to Site
        </a>
        <a href="{{ basePath }}/logout" class="sidebar-link sidebar-link-danger">
            <i class="bi bi-box-arrow-left"></i> Sign Out
        </a>
    </aside>

    {# Main area #}
    <div class="admin-main">
        <div class="admin-topbar">
            <h5>{% block page_title %}My Account{% endblock %}</h5>
            <span class="text-muted small">{{ session.name }}</span>
        </div>
        <div class="admin-content">
            {% if flash %}
            <div class="alert alert-{{ flash.type }} alert-dismissible fade show mb-4" role="alert">
                {{ flash.message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
            {% endif %}
            {% block content %}{% endblock %}
        </div>
    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
{% block extra_js %}{% endblock %}
</body>
</html>
