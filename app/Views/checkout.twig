{% extends 'layout.twig' %}
{% block title %}Checkout — CraveCart{% endblock %}

{% block extra_css %}
<link rel="stylesheet" href="{{ asset_url('/css/checkout.css') }}">
{% endblock %}

{% block content %}
<section class="checkout-section py-5">
    <div class="container">

        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="{{ basePath }}/" class="breadcrumb-link">Home</a></li>
                <li class="breadcrumb-item"><a href="{{ basePath }}/cart" class="breadcrumb-link">Cart</a></li>
                <li class="breadcrumb-item active">Checkout</li>
            </ol>
        </nav>

        {% if errors is defined and errors %}
        <div class="alert alert-danger">
            <ul class="mb-0 ps-3">
                {% for error in errors %}
                    <li class="small">{{ error }}</li>
                {% endfor %}
            </ul>
        </div>
        {% endif %}

        <form action="{{ basePath }}/checkout/place" method="post">
        <div class="row g-4">

            {# Left — delivery address form #}
            <div class="col-lg-7">
                <div class="checkout-card">
                    <h6><i class="bi bi-geo-alt me-2 icon-red"></i>Delivery Address</h6>
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label small fw-semibold">Full Name</label>
                            <input type="text" name="name" class="form-control"
                                   placeholder="John Doe"
                                   value="{{ old.name ?? '' }}" required>
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-semibold">Street Address</label>
                            <input type="text" name="street" class="form-control"
                                   placeholder="123 Main Street"
                                   value="{{ old.street ?? '' }}" required>
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-semibold">City</label>
                            <input type="text" name="city" class="form-control"
                                   placeholder="Montreal"
                                   value="{{ old.city ?? '' }}" required>
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-semibold">Postal Code</label>
                            <input type="text" name="postal_code" class="form-control"
                                   placeholder="H2X 1Y4"
                                   value="{{ old.postal_code ?? '' }}" required>
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-semibold">Order Notes <span class="text-muted fw-normal">(optional)</span></label>
                            <input type="text" name="notes" class="form-control"
                                   placeholder="e.g. Leave at the door"
                                   value="{{ old.notes ?? '' }}">
                        </div>
                    </div>
                </div>
            </div>

            {# Right — order summary #}
            <div class="col-lg-5">
                <div class="checkout-card checkout-summary">
                    <h6><i class="bi bi-bag me-2 icon-red"></i>Order Summary</h6>

                    <div class="mb-4">
                        {% for item in items %}
                        <div class="item-line">
                            <span class="item-emoji">{{ item.emoji }}</span>
                            <span class="item-name">{{ item.name }}</span>
                            <span class="item-qty">x{{ item.quantity }}</span>
                            <span class="item-price">${{ (item.price * item.quantity)|number_format(2) }}</span>
                        </div>
                        {% endfor %}
                    </div>

                    <hr>

                    <div class="summary-row"><span class="text-muted">Subtotal</span><span>${{ subtotal }}</span></div>
                    <div class="summary-row"><span class="text-muted">Delivery fee</span><span>${{ delivery_fee }}</span></div>
                    <div class="summary-row"><span class="text-muted">Tax (13%)</span><span>${{ tax }}</span></div>
                    <hr>
                    <div class="summary-row total"><span>Total</span><span>${{ total }}</span></div>

                    <div class="mt-4">
                        <button type="submit" class="btn-place-order">
                            <i class="bi bi-bag-check me-2"></i>Place Order
                        </button>
                    </div>

                    <p class="text-center small text-muted mt-3 mb-0">
                        <i class="bi bi-shield-lock me-1"></i> Secure checkout
                    </p>
                </div>
            </div>

        </div>
        </form>

    </div>
</section>
{% endblock %}
