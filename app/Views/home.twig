{% extends 'layout.twig' %}
{% block title %}CraveCart — What are you craving?{% endblock %}

{% block extra_css %}
<link rel="stylesheet" href="{{ asset_url('/css/home.css') }}">
{% endblock %}

{% block extra_js %}
<script src="{{ asset_url('/js/home.js') }}"></script>
{% endblock %}

{% block content %}

{# Hero #}
<section class="cc-hero">
    <div class="cc-hero-text">
        <h1>What are you craving?</h1>
        <p>Explore cuisines from around the world</p>
    </div>
</section>

{# Popular Cuisines #}
<section class="py-5" style="background:#fff;">
    <div class="container">
        <h2 class="text-center fw-800 mb-4" style="font-weight:800; font-size:1.6rem; letter-spacing:-.02em;">Popular Cuisines</h2>
        <div class="row g-3">

             {% for cuisine in cuisines %}
                <div class="col-6 col-md-3">
                    <a href="{{ basePath }}/browse/food/{{ cuisine.slug }}" class="cuisine-card">
                        <img src="{{ cuisine.image_url }}" alt="{{ cuisine.name }}">
                        <div class="overlay"></div>
                        <div class="card-label">
                            <span class="code">{{ cuisine.code }}</span>
                            <span class="name">{{ cuisine.name }}</span>
                        </div>
                    </a>
                </div>
            {% endfor %}

        </div>
    </div>
</section>

{% endblock %}
